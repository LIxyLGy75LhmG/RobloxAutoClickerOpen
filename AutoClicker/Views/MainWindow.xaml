<Window x:Class="AutoClicker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:commands="clr-namespace:AutoClicker.Commands"
        xmlns:enums="clr-namespace:AutoClicker.Enums"
        ResizeMode="CanMinimize"
        Background="{StaticResource BgDarkBrush}"
        Height="640" Width="470">
    <Window.Resources>
        <ResourceDictionary Source="../Resources/MainWindowResources.xaml"/>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="commands:MainWindowCommands.Start"
                        Executed="StartCommand_Execute" CanExecute="StartCommand_CanExecute"/>
        <CommandBinding Command="commands:MainWindowCommands.Stop"
                        Executed="StopCommand_Execute" CanExecute="StopCommand_CanExecute"/>
        <CommandBinding Command="commands:MainWindowCommands.Toggle"
                        Executed="ToggleCommand_Execute" CanExecute="ToggleCommand_CanExecute"/>
        <CommandBinding Command="commands:MainWindowCommands.SaveSettings"
                        Executed="SaveSettingsCommand_Execute"/>
        <CommandBinding Command="commands:MainWindowCommands.HotkeySettings"
                        Executed="HotkeySettingsCommand_Execute"/>
        <CommandBinding Command="commands:MainWindowCommands.Exit"
                        Executed="ExitCommand_Execute"/>
        <CommandBinding Command="commands:MainWindowCommands.About"
                        Executed="AboutCommand_Execute"/>
        <CommandBinding Command="commands:MainWindowCommands.CaptureMouseScreenCoordinates"
                        Executed="CaptureMouseScreenCoordinatesCommand_Execute"/>
    </Window.CommandBindings>

    <Grid Name="mainWindowGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#FF12192B">
            <MenuItem Header="_Help" Foreground="#FFEEF2F7">
                <MenuItem Header="_About" Click="AboutMenuItem_Click" Foreground="#FF0B1220"/>
                <MenuItem Header="Minimize to tray" Click="MinimizeMenuItem_Click" Foreground="#FF0B1220"/>
            </MenuItem>
            <MenuItem Header="_Exit" Click="ExitMenuItem_Click" Foreground="#FFEEF2F7"/>
        </Menu>

        <Border Grid.Row="1" Background="#FF12192B" Padding="10,7">
            <TextBlock TextAlignment="Center" FontSize="12" Foreground="#FFFBBF24" TextWrapping="Wrap">
                How to use:  1) set the click speed   ·   2) choose WHERE to click   ·   3) press Start (F6)
            </TextBlock>
        </Border>

        <Grid Grid.Row="2">
            <Image Source="/Resources/mascot.png" Width="92"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,10"/>

            <Grid Name="primaryGrid" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Click Interval (how often)" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Width="45"
                                 Text="{Binding AutoClickerSettings.Hours, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="1" Margin="5,0,5,5" Text="hours"/>
                        <TextBox Grid.Column="2" Width="45"
                                 Text="{Binding AutoClickerSettings.Minutes, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="3" Margin="5,0,5,5" Text="minutes"/>
                        <TextBox Grid.Column="4" Width="45"
                                 Text="{Binding AutoClickerSettings.Seconds, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="5" Margin="5,0,5,5" Text="seconds"/>
                        <TextBox Grid.Column="6" Width="45"
                                 Text="{Binding AutoClickerSettings.Milliseconds, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="7" Margin="5,0,5,5" Text="ms"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Click Repeat" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Row="0" Grid.Column="0" Margin="0,0,0,5"
                                     Content="Infinite (Until stopped)"
                                     IsChecked="{Binding AutoClickerSettings.SelectedRepeatMode,
                                                         Converter={StaticResource EnumToBooleanConverter},
                                                         ConverterParameter={x:Static enums:RepeatMode.Infinite}}"/>
                        <RadioButton Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,5"
                                     IsChecked="{Binding AutoClickerSettings.SelectedRepeatMode,
                                                         Converter={StaticResource EnumToBooleanConverter},
                                                         ConverterParameter={x:Static enums:RepeatMode.Count}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Width="50" Margin="5,0,0,0"
                                         Text="{Binding AutoClickerSettings.SelectedTimesToRepeat,
                                                        UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                                <TextBlock Text="Times" Margin="5,0,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Click Position (WHERE to click)" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,5,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton GroupName="SelectedLocationMode"
                                     Name="RadioButtonSelectedLocationMode_CurrentLocation"
                                     Grid.Row="0" Grid.Column="0" Margin="0,0,0,5"
                                     Content="Current Cursor Position"
                                     IsChecked="{Binding AutoClickerSettings.SelectedLocationMode,
                                                Converter={StaticResource EnumToBooleanConverter},
                                                ConverterParameter={x:Static enums:LocationMode.CurrentLocation}}"/>
                        <RadioButton GroupName="SelectedLocationMode"
                                     Name="RadioButtonSelectedLocationMode_PickedLocation"
                                     Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,5"
                                     IsChecked="{Binding AutoClickerSettings.SelectedLocationMode,
                                                Converter={StaticResource EnumToBooleanConverter},
                                                ConverterParameter={x:Static enums:LocationMode.PickedLocation}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="X" Margin="5,0,0,0"/>
                                <TextBox Width="50" Margin="5,0,0,5" Name="TextBoxPickedXValue"
                                         Text="{Binding AutoClickerSettings.PickedXValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                                <TextBlock Text="Y" Margin="5,0,0,0"/>
                                <TextBox Width="50" Margin="5,0,0,5" Name="TextBoxPickedYValue"
                                         Text="{Binding AutoClickerSettings.PickedYValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                                <Button Name="CaptureMouseScreenCoordinatesButton"
                                        Margin="5,0,0,0" Width="22" Height="22"
                                        ToolTip="Click this, then click anywhere on screen to set the target point."
                                        Command="commands:MainWindowCommands.CaptureMouseScreenCoordinates">
                                    <Image Source="/Resources/Icons/location-crosshairs-solid.ico"/>
                                </Button>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Click Options" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4">
                    <UniformGrid HorizontalAlignment="Center" VerticalAlignment="Stretch" Rows="1" Columns="4">
                        <TextBlock Text="Mouse Button" Margin="5" VerticalAlignment="Center" TextAlignment="Center"/>
                        <ComboBox Margin="5" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Source={StaticResource mouseButtonValues}}"
                                  SelectedIndex="0" SelectedItem="{Binding AutoClickerSettings.SelectedMouseButton}"/>
                        <TextBlock Text="Click Type" Margin="5" VerticalAlignment="Center" TextAlignment="Center"/>
                        <ComboBox Margin="0,5,5,5" HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Source={StaticResource mouseActionValues}}"
                                  SelectedIndex="0" SelectedItem="{Binding AutoClickerSettings.SelectedMouseAction}"/>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="AFK / Anti-Idle" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4">
                    <CheckBox Name="afkModeCheckBox" Margin="5"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Content="Keep me active — auto-click every 30s (no idle kick)"
                              Checked="AfkModeCheckBox_CheckedChanged" Unchecked="AfkModeCheckBox_CheckedChanged"/>
                </GroupBox>

                <UniformGrid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Rows="2" Columns="3">
                    <Button Name="startButton" Margin="5" Content="Start (F6)"
                            Command="commands:MainWindowCommands.Start"/>
                    <Button Name="stopButton" Margin="5" Content="Stop (F7)"
                            Command="commands:MainWindowCommands.Stop"/>
                    <Button Name="toggleButton" Margin="5" Content="Toggle (F8)"
                            Command="commands:MainWindowCommands.Toggle"/>
                    <Button Name="saveSettingsButton" Margin="5" Content="Save Settings"
                            Command="commands:MainWindowCommands.SaveSettings"/>
                    <Button Name="hotkeysButton" Margin="5" Content="Hotkeys"
                            Command="commands:MainWindowCommands.HotkeySettings"/>
                    <CheckBox Name="topMostCheckBox" Margin="5"
                              VerticalAlignment="Center" HorizontalAlignment="Center"
                              Content="Top most window"
                              Checked="TopMostCheckBox_CheckedChanged" Unchecked="TopMostCheckBox_CheckedChanged"/>
                </UniformGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>
